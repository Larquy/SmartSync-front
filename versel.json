{
  "version": 2,
  "builds": [
    {
      "src": "control-center/html/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "control-center/html/dispatch.html",
      "use": "@vercel/static"
    },
    {
      "src": "control-center/html/emergency.html",
      "use": "@vercel/static"
    },
    {
      "src": "control-center/html/analytics.html",
      "use": "@vercel/static"
    },
    {
      "src": "control-center/html/settings.html",
      "use": "@vercel/static"
    },
    {
      "src": "client/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "sub-station/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/control-center/html/index.html"
    },
    {
      "src": "/dispatch",
      "dest": "/control-center/html/dispatch.html"
    },
    {
      "src": "/emergency",
      "dest": "/control-center/html/emergency.html"
    },
    {
      "src": "/analytics",
      "dest": "/control-center/html/analytics.html"
    },
    {
      "src": "/settings",
      "dest": "/control-center/html/settings.html"
    },
    {
      "src": "/client",
      "dest": "/client/index.html"
    },
    {
      "src": "/sub-station",
      "dest": "/sub-station/index.html"
    }
  ]
}
