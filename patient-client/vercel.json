{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/home",
      "dest": "/pages/home.html"
    },
    {
      "src": "/chat",
      "dest": "/pages/chat.html"
    },
    {
      "src": "/emergency",
      "dest": "/pages/emergency.html"
    },
    {
      "src": "/family-mode",
      "dest": "/pages/family-mode.html"
    },
    {
      "src": "/navigation",
      "dest": "/pages/navigation.html"
    },
    {
      "src": "/overview",
      "dest": "/pages/overview.html"
    },
    {
      "src": "/profile",
      "dest": "/pages/profile.html"
    },
    {
      "src": "/progress",
      "dest": "/pages/progress.html"
    },
    {
      "src": "/queue",
      "dest": "/pages/queue.html"
    },
    {
      "src": "/rating",
      "dest": "/pages/rating.html"
    },
    {
      "src": "/reminder",
      "dest": "/pages/reminder.html"
    },
    {
      "src": "/report-detail",
      "dest": "/pages/report-detail.html"
    },
    {
      "src": "/reports",
      "dest": "/pages/reports.html"
    },
    {
      "src": "/task-detail",
      "dest": "/pages/task-detail.html"
    },
    {
      "src": "/trace",
      "dest": "/pages/trace.html"
    },
    {
      "src": "/nfc-bind",
      "dest": "/pages/nfc-bind.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, HEAD, OPTIONS"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    }
  ]
}
