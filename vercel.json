{
  "version": 2,
  "buildCommand": "mkdir -p public && cp -r front/* public/",
  "outputDirectory": "public",
  "builds": [
    {
      "src": "public/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/dispatch",
      "dest": "/control-center/html/dispatch.html"
    },
    {
      "src": "/emergency",
      "dest": "/control-center/html/emergency.html"
    },
    {
      "src": "/analytics",
      "dest": "/control-center/html/analytics.html"
    },
    {
      "src": "/settings",
      "dest": "/control-center/html/settings.html"
    },
    {
      "src": "/client",
      "dest": "/patient-client.html"
    },
    {
      "src": "/sub-station",
      "dest": "/sub-station.html"
    },
    {
      "src": "/(.*)",
      "dest": "/control-center/html/index.html"
    }
  ]
}
